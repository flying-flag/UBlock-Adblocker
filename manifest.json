{
  "name": "UBlock Adblocker",
  "description": "",
  "version": "1.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [{
      "matches": ["<all_urls>"],
      "resources": ["error.html"]
  }],
  "permissions": [
    "storage"
  ],
  "options_page": "options.html",
  "icons": {
      "128": "icon.png"
   }
}